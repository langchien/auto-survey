{
  "manifest_version": 3,
  "name": "Auto Survey Form",
  "version": "1.0",
  "description": "Tiện ích tự động điền form khảo sát",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tự động điền khảo sát"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"], 
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
